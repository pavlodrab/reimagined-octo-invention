# .env.example — скопируйте в .env и заполните

# Обязательно: токен бота от @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# URL мини-приложения (HTTPS!)
# Для локальной разработки используйте ngrok: ngrok http 5000
# Затем вставьте сюда HTTPS-адрес из ngrok
MINI_APP_URL=https://your-domain.com

# Ваш Telegram user ID (узнать у @userinfobot) — станет владельцем/админом.
# Это ЕДИНСТВЕННЫЙ способ получить админку с нуля. Без OWNER_ID все админ-эндпоинты вернут 403.
OWNER_ID=123456789

# Токен API sstats.net (можно задать позже через админку)
SSTATS_TOKEN=sjzgn3bbco67pk8j

# Порт Flask-сервера
PORT=5000

# ── База данных ────────────────────────────────────────────────────────
# Оставь DATABASE_URL пустым/незаданным для локальной разработки на SQLite.
# В Railway / production задай DATABASE_URL — приложение автоматически
# переключится на Postgres (Railway добавляет эту переменную автоматически
# при подключении Postgres add-on'а).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Только если используется SQLite (DATABASE_URL пустой):
# Папка для файла chelsea_bot.db. По умолчанию /tmp — но на Railway /tmp
# стирается при каждом редеплое! Используй mounted volume для персистентности.
DB_DIR=/tmp

# ── Режим разработки ───────────────────────────────────────────────────
# DEMO_MODE=1 разрешает аутентификацию через незаверенные заголовки
# (X-Demo-User) и query-параметры (?user_id=) — для локального тестирования
# без настоящего Telegram WebApp.
# В ПРОДАКШНЕ ДОЛЖНО БЫТЬ 0 (или не задано). Иначе любой может выдать себя
# за любого юзера, включая админа.
DEMO_MODE=0

# Максимальный возраст initData в секундах (защита от replay-атак).
# По умолчанию 24 часа = 86400 (рекомендация Telegram).
INIT_DATA_MAX_AGE=86400

# ── Rate limiting ──────────────────────────────────────────────────────
# Лимиты для всех /api/* по умолчанию (per-user или per-IP). Можно ослабить
# или ужесточить через эти переменные. Конкретные admin/write endpoint-ы
# имеют дополнительные жёсткие лимиты прямо в коде.
RATE_LIMIT_DEFAULT_PER_MINUTE=100 per minute
RATE_LIMIT_DEFAULT_PER_HOUR=2000 per hour

# Хранилище счётчиков. По умолчанию memory:// (на каждый воркер свой счётчик).
# Для точной работы при нескольких Gunicorn воркерах используй Redis:
# RATELIMIT_STORAGE_URI=redis://default:password@host:port/0
# RATELIMIT_STORAGE_URI=memory://

# ── Логирование и мониторинг ───────────────────────────────────────────
# Уровень логов: DEBUG, INFO (default), WARNING, ERROR
LOG_LEVEL=INFO
# Формат: plain (default, человекочитаемо) или json (для Loki/Datadog/Cloudwatch)
LOG_FORMAT=plain

# Sentry (опционально — оставь пустым чтобы выключить).
# Регистрируйся на sentry.io, создай Python проект, скопируй DSN.
# SENTRY_DSN=https://your_key@o12345.ingest.sentry.io/678901
# SENTRY_ENV=production
# Доля запросов, по которым собираются APM-traces (0..1). 0 = только ошибки.
# SENTRY_TRACES_RATE=0
